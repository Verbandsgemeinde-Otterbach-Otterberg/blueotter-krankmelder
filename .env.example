# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM_EMAIL=noreply@municipality.de

# Email Recipients
SB_EMAIL=sachbearbeiter@municipality.de
EMAIL_SUBJECT_PREFIX=Krankmeldessystem

# App Configuration
NEXT_PUBLIC_APP_NAME=BlueOtter
NEXT_PUBLIC_APP_SLOGAN=Einfach, schnell und zuverlässig – Ihre Krankmeldungen in einem Klick!

# Database
DATABASE_URL=./data/krankmeldungen.db

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# Retention
FILE_RETENTION_DAYS=365

# Security - Passwords (accessible to client)
# Server-only passwords (do NOT prefix with NEXT_PUBLIC_)
# Password for normal access (used to access non-admin areas)
PUBLIC_PASSWORD=replace-with-public-access-password
# Username and password for admin dashboard access
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=replace-with-admin-password

# Employers (JSON array for dropdown in forms) - sorted alphabetically by Ortsnamen
EMPLOYERS=["Organisationseinheit A","Organisationseinheit B","Organisationseinheit C"]

# Note: Keep these variables private. Do NOT expose them as NEXT_PUBLIC_*
